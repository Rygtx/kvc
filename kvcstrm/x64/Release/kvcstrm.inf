;
; kvcstrm.inf
;

[Version]
Signature   = "$WINDOWS NT$"
Class       = System ; TODO: specify appropriate Class
ClassGuid   = {4d36e97d-e325-11ce-bfc1-08002be10318} ; TODO: specify appropriate ClassGuid
Provider    = %ManufacturerName%
CatalogFile = kvcstrm.cat
DriverVer = 04/05/2026,23.3.38.332
PnpLockdown = 1

[DestinationDirs]
DefaultDestDir = 13

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
kvcstrm.sys  = 1,,

;*****************************************
; Install Section
;*****************************************

[Manufacturer]
%ManufacturerName% = Standard,NTamd64.10.0...16299 ; %13% support introduced in build 16299

[Standard.NTamd64.10.0...16299]
%kvcstrm.DeviceDesc% = kvcstrm_Device, Root\kvcstrm ; TODO: edit hw-id

[kvcstrm_Device.NT]
CopyFiles = File_Copy

[File_Copy]
kvcstrm.sys

;-------------- Service installation
[kvcstrm_Device.NT.Services]
AddService = kvcstrm,%SPSVCINST_ASSOCSERVICE%, kvcstrm_Service_Inst

; -------------- kvcstrm driver install sections
[kvcstrm_Service_Inst]
DisplayName    = %kvcstrm.SVCDESC%
ServiceType    = 1               ; SERVICE_KERNEL_DRIVER
StartType      = 3               ; SERVICE_DEMAND_START
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\kvcstrm.sys

[kvcstrm_Device.NT.Wdf]
KmdfService = kvcstrm, kvcstrm_wdfsect

[kvcstrm_wdfsect]
KmdfLibraryVersion = 1.15

[Strings]
SPSVCINST_ASSOCSERVICE = 0x00000002
ManufacturerName = "<Your manufacturer name>" ;TODO: Replace with your manufacturer name
DiskName = "kvcstrm Installation Disk"
kvcstrm.DeviceDesc = "kvcstrm Device"
kvcstrm.SVCDESC = "kvcstrm Service"
